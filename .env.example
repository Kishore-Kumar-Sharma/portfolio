# ─── Environment Variables Template ──────────────────────────────────────────
# Copy this file to .env.local for development.
# For production, add these variables in your Vercel project → Settings → Environment Variables.
# ─────────────────────────────────────────────────────────────────────────────

# Site
BASE_URL=""
GA_MEASUREMENT_ID=""

# Gmail SMTP (Nodemailer)
GMAIL_USER=your-email@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# ─── Upstash Redis (rate limiting) ───────────────────────────────────────────
# Free tier: console.upstash.com → Create database → REST API tab.
# Without these, dev falls back to a per-instance in-memory limiter.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ─── Cloudflare Turnstile (bot protection on the contact form) ───────────────
# Free, unlimited: dash.cloudflare.com → Turnstile → Add site.
# Site key is exposed to the browser; secret key MUST stay server-side.
# Without these, dev skips verification so the form still submits locally.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

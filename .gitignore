# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files — protect secrets, allow safe files to be committed
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env.production
# .env.production and .env.example are safe to commit (no secrets inside)

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# IDE, Editor and AI contexts
.idx/
.vscode/
.gemini/
.cursor/
.idea/
*.swp
blueprint.md
GEMINI.md
firebase-debug.log
.docs/
